{
  "name": "qdcli-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.1.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "dev:view": "pnpm --filter @qdcli/viewer dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml,nix}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml,nix}\"",
    "lint": "oxlint .",
    "pack": "pnpm --filter qdcli pack --dry-run",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "prettier": "^3.7.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
